{
  "entities": {
    "usuario": {
      "title": "Usuário",
      "description": "Perfil de usuário do sistema (Admin ou Funcionário)",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "tipo": { "type": "string", "enum": ["admin", "funcionario"] },
        "ativo": { "type": "boolean" },
        "criadoEm": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "email", "tipo", "ativo", "criadoEm"]
    },
    "produto": {
      "title": "Produto",
      "description": "Catálogo de produtos / bebidas",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "costPrice": { "type": "number" },
        "salePrice": { "type": "number" },
        "supplier": { "type": "string" },
        "alertThreshold": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "cliente": {
      "title": "Cliente",
      "description": "Base de clientes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "observations": { "type": "string" }
      }
    },
    "venda": {
      "title": "Venda",
      "description": "Registro de vendas finalizadas",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "items": { "type": "array" }
      }
    },
    "caixa": {
      "title": "Caixa",
      "description": "Movimentações financeiras (Entradas/Saídas)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "entrega": {
      "title": "Entrega",
      "description": "Pedidos de delivery",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientName": { "type": "string" },
        "status": { "type": "string" },
        "total": { "type": "number" }
      }
    },
    "aluguel": {
      "title": "Aluguel",
      "description": "Locação de materiais para eventos",
      "type": "object"
    },
    "orcamento": {
      "title": "Orçamento",
      "description": "Documentos de orçamento gerados",
      "type": "object"
    },
    "estoque": {
      "title": "Estoque",
      "description": "Logs de movimentação de estoque",
      "type": "object"
    }
  },
  "firestore": {
    "usuarios/{userId}": {
      "schema": "usuario",
      "description": "Perfis de usuários"
    },
    "produtos/{id}": {
      "schema": "produto",
      "description": "Catálogo de estoque"
    },
    "clientes/{id}": {
      "schema": "cliente",
      "description": "Cadastro de clientes"
    },
    "vendas/{id}": {
      "schema": "venda",
      "description": "Fechamento de vendas"
    },
    "caixa/{id}": {
      "schema": "caixa",
      "description": "Livro caixa"
    },
    "entregas/{id}": {
      "schema": "entrega",
      "description": "Controle de delivery"
    },
    "alugueis/{id}": {
      "schema": "aluguel",
      "description": "Locações"
    },
    "orcamentos/{id}": {
      "schema": "orcamento",
      "description": "Histórico de orçamentos"
    },
    "estoque/{id}": {
      "schema": "estoque",
      "description": "Movimentações detalhadas de estoque"
    }
  }
}
