rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'alexx.albertini@gmail.com'
      );
    }

    function isStaff() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    // Users
    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Deliveries
    match /entregas/{deliveryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Transactions / Ledger
    match /caixa/{transactionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In some cases staff needs to log expenses
    }

    // Sales
    match /vendas/{saleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Products
    match /produtos/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Rentals
    match /alugueis/{rentalId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Clients
    match /clientes/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Quotes
    match /orcamentos/{quoteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
