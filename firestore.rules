rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.tipo == 'admin' ||
        request.auth.token.email.toLowerCase() == 'eskinaoservefest@gmail.com'
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'tipo', 'ativo']) &&
             data.email is string &&
             data.tipo in ['admin', 'funcionario'] &&
             data.ativo is bool;
    }

    // Users
    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) || isAdmin();
    }

    // Shared collections - allowing reads/writes for authenticated users
    // In production, these should be locked down to relevant businessId if multi-tenant
    match /produtos/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }
    
    match /clientes/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /vendas/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /caixa/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /entregas/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /alugueis/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /orcamentos/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /estoque/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
